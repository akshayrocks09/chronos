<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="2-indexes" author="antigravity">
        <createIndex indexName="idx_schedule_time" tableName="jobs">
            <column name="scheduled_at"/>
        </createIndex>
        <createIndex indexName="idx_status" tableName="jobs">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_user_id" tableName="jobs">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
